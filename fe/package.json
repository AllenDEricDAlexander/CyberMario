{
  "name": "fe",
  "private": true,
  "version": "0.0.0",
  "packageManager": "bun@1.3.14",
  "type": "module",
  "scripts": {
    "dev": "bun run --bun vite",
    "build": "bun run --bun tsc -b && bun run --bun vite build",
    "lint": "bun run --bun eslint .",
    "preview": "bun run --bun vite preview",
    "typecheck": "bun run --bun tsc -b --noEmit",
    "test": "bun run --bun vitest run",
    "test:coverage": "bun run --bun vitest run --coverage",
    "analyze": "bun run --bun vite build --mode analyze"
  },
  "dependencies": {
    "@ant-design/charts": "^2.6.7",
    "@ant-design/icons": "^6.2.5",
    "@ant-design/x": "^2.8.0",
    "@ant-design/x-sdk": "^2.8.0",
    "antd": "^6.4.4",
    "axios": "^1.18.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-router": "^7.17.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.8"
  }
}
